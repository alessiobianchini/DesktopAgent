{
    "AdapterEndpoint":  "http://localhost:51877",
    "AllowedApps":  [
                        "notepad",
                        "calculator",
                        "calc",
                        "terminal",
                        "cmd",
                        "powershell"
                    ],
    "AppAliases":  {
                       "visual studio":  "code",
                       "visual studio code":  "code",
                       "vs code":  "code",
                       "vscode":  "code",
                       "notepad plus plus":  "notepad++",
