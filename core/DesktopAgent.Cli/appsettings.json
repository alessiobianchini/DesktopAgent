                       "blocco note":  "notepad",
                       "calcolatrice":  "calc",
                       "esplora risorse":  "explorer",
                       "file explorer":  "explorer"
                   },
    "AppIndexCachePath":  "app-index.json",
    "AppIndexCacheTtlMinutes":  1440,
    "NewFileKeyCombo":  [
                            "ctrl",
                            "n"
                        ],
    "SaveKeyCombo":  [
                         "ctrl",
                         "s"
                     ],
    "SaveAsKeyCombo":  [
                           "ctrl",
                           "shift",
                           "s"
                       ],
    "NewTabKeyCombo":  [
                           "ctrl",
                           "t"
                       ],
    "CloseTabKeyCombo":  [
                             "ctrl",
                             "w"
                         ],
    "CloseWindowKeyCombo":  [
                                "alt",
                                "f4"
                            ],
    "CopyKeyCombo":  [
                         "ctrl",
                         "c"
                     ],
    "PasteKeyCombo":  [
                          "ctrl",
                          "v"
                      ],
    "UndoKeyCombo":  [
                         "ctrl",
                         "z"
                     ],
    "RedoKeyCombo":  [
                         "ctrl",
                         "y"
                     ],
    "SelectAllKeyCombo":  [
                              "ctrl",
                              "a"
                          ],
