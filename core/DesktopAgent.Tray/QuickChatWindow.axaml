<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DesktopAgent.Tray.QuickChatWindow"
        Title="DesktopAgent Quick Chat"
        RequestedThemeVariant="Dark"
        Width="960"
        Height="760"
        MinWidth="860"
        MinHeight="620"
        Background="#0A0E14"
        Foreground="#E6EDF7">
  <Grid RowDefinitions="Auto,Auto,*" Margin="12">
    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
      <TextBlock Text="DesktopAgent Control Center" FontSize="20" FontWeight="SemiBold" />
      <TextBlock x:Name="VersionText" Grid.Row="1" Text="Version: -" FontSize="12" Opacity="0.8" Margin="0,2,0,0" />
      <StackPanel Grid.Column="1" Grid.RowSpan="2" Margin="12,0,0,0" Spacing="4" VerticalAlignment="Center">
        <WrapPanel ItemHeight="24">
          <Border x:Name="ArmedStateBadge" Background="#2A3344" BorderBrush="#3C4A63" BorderThickness="1" CornerRadius="12" Padding="8,2" Margin="0,0,6,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock x:Name="ArmedStateIcon" Text="🛡" FontSize="12" VerticalAlignment="Center" />
              <TextBlock x:Name="ArmedStateText" Text="ARMED ?" FontSize="11" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
          <Border x:Name="PresenceStateBadge" Background="#2A3344" BorderBrush="#3C4A63" BorderThickness="1" CornerRadius="12" Padding="8,2" Margin="0,0,6,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock x:Name="PresenceStateIcon" Text="🔐" FontSize="12" VerticalAlignment="Center" />
              <TextBlock x:Name="PresenceStateText" Text="PRESENCE ?" FontSize="11" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
          <Border x:Name="LlmStateBadge" Background="#2A3344" BorderBrush="#3C4A63" BorderThickness="1" CornerRadius="12" Padding="8,2" Margin="0,0,6,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock x:Name="LlmStateIcon" Text="🧠" FontSize="12" VerticalAlignment="Center" />
              <TextBlock x:Name="LlmStateText" Text="LLM ?" FontSize="11" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
          <Border x:Name="KillStateBadge" Background="#2A3344" BorderBrush="#3C4A63" BorderThickness="1" CornerRadius="12" Padding="8,2">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock x:Name="KillStateIcon" Text="⛔" FontSize="12" VerticalAlignment="Center" />
              <TextBlock x:Name="KillStateText" Text="KILL ?" FontSize="11" FontWeight="SemiBold" />
            </StackPanel>
          </Border>
        </WrapPanel>
        <TextBlock x:Name="StatusText" FontSize="11" Opacity="0.78" Text="Status: loading..." />
      </StackPanel>
    </Grid>

    <Border Grid.Row="1"
            Margin="0,10,0,10"
            Padding="8"
            Background="#101723"
            BorderBrush="#2A3950"
            BorderThickness="1"
            CornerRadius="8">
      <WrapPanel ItemHeight="34">
        <Button x:Name="StatusButton" Content="Status" MinWidth="88" Margin="0,0,8,0" />
        <Button x:Name="ArmButton" Content="Arm" MinWidth="88" Margin="0,0,8,0" />
        <Button x:Name="DisarmButton" Content="Disarm" MinWidth="88" Margin="0,0,8,0" />
        <Button x:Name="SimPresenceButton" Content="Sim Presence" MinWidth="106" Margin="0,0,8,0" />
        <Button x:Name="ReqPresenceButton" Content="Req Presence" MinWidth="106" Margin="0,0,8,0" />
        <Button x:Name="KillButton" Content="Kill" MinWidth="88" Margin="0,0,8,0" />
        <Button x:Name="ResetKillButton" Content="Reset Kill" MinWidth="96" Margin="0,0,8,0" />
        <Button x:Name="RestartAdapterButton" Content="Restart Adapter" MinWidth="126" Margin="0,0,8,0" />
        <Button x:Name="RestartServerButton" Content="Restart Server" MinWidth="122" Margin="0,0,8,0" />
        <Button x:Name="LockWindowButton" Content="Lock Window" MinWidth="108" Margin="0,0,8,0" />
        <Button x:Name="LockAppButton" Content="Lock App" MinWidth="98" Margin="0,0,8,0" />
        <Button x:Name="UnlockButton" Content="Unlock" MinWidth="90" Margin="0,0,8,0" />
        <Button x:Name="ProfileSafeButton" Content="Profile Safe" MinWidth="108" Margin="0,0,8,0" />
        <Button x:Name="ProfileBalancedButton" Content="Profile Balanced" MinWidth="126" Margin="0,0,8,0" />
        <Button x:Name="ProfilePowerButton" Content="Profile Power" MinWidth="116" Margin="0,0,8,0" />
        <Button x:Name="CopyButton" Content="Copy Log" MinWidth="96" Margin="0,0,8,0" />
        <Button x:Name="ClearButton" Content="Clear" MinWidth="76" />
      </WrapPanel>
    </Border>

    <TabControl Grid.Row="2" x:Name="MainTabs">
      <TabItem x:Name="ChatTab">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Chat" />
            <Border x:Name="ChatTabBadgePanel"
                    IsVisible="False"
                    Background="#2C4F8A"
                    CornerRadius="10"
                    Padding="6,1"
                    MinWidth="20">
              <TextBlock x:Name="ChatTabBadgeText"
                         Text="0"
                         HorizontalAlignment="Center"
                         FontSize="11"
                         FontWeight="SemiBold" />
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" Margin="2">
          <Border x:Name="ChatUpdateBadgePanel"
                  Grid.Row="0"
                  Margin="0,0,0,10"
                  Padding="8"
                  CornerRadius="6"
                  Background="#1B2A14"
                  BorderBrush="#446B35"
                  BorderThickness="1"
                  IsVisible="False">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock x:Name="ChatUpdateBadgeText" Text="Update available" VerticalAlignment="Center" />
              <Button x:Name="ChatUpdateDetailsButton" Grid.Column="1" Content="Details" MinWidth="88" Margin="10,0,0,0" />
              <Button x:Name="ChatApplyUpdateButton" Grid.Column="2" Content="Apply now" MinWidth="96" Margin="10,0,0,0" />
            </Grid>
          </Border>

          <Border BorderBrush="#2A3950"
                  Grid.Row="1"
                  BorderThickness="1"
                  CornerRadius="8"
                  Background="#0F1520"
                  Padding="8">
            <TextBox x:Name="HistoryBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VerticalContentAlignment="Top"
                     Background="#0F1520"
                     Foreground="#E6EDF7"
                     BorderThickness="0"
                     FontFamily="Cascadia Mono, Consolas, monospace"
                     FontSize="13" />
          </Border>

          <StackPanel x:Name="ConfirmPanel"
                      Grid.Row="2"
                      Orientation="Horizontal"
                      Spacing="8"
                      Margin="0,10,0,10"
                      IsVisible="False">
            <TextBlock x:Name="ConfirmText" Text="Confirmation required." VerticalAlignment="Center" />
            <Button x:Name="ConfirmButton" Content="Confirm" MinWidth="110" />
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="100" />
          </StackPanel>

          <Border x:Name="BusyPanel"
                  Grid.Row="3"
                  Margin="0,0,0,10"
                  Padding="8"
                  IsVisible="False"
                  Background="#142033"
                  BorderBrush="#2A3950"
                  BorderThickness="1"
                  CornerRadius="6">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
              <ProgressBar Width="110" Height="6" IsIndeterminate="True" />
              <TextBlock x:Name="BusyText" Text="Waiting for agent response..." VerticalAlignment="Center" />
              <Button x:Name="CancelRequestButton" Content="Cancel" MinWidth="80" />
            </StackPanel>
          </Border>

          <ListBox x:Name="CommandPaletteList"
                   Grid.Row="4"
                   Margin="0,0,0,10"
                   MinHeight="40"
                   MaxHeight="120"
                   IsVisible="False" />

          <Grid Grid.Row="5" ColumnDefinitions="*,Auto,Auto">
            <TextBox x:Name="InputBox"
                     Watermark="Write command in natural language..."
                     TextWrapping="Wrap"
                     AcceptsReturn="False"
                     Background="#0F1520"
                     Foreground="#E6EDF7"
                     BorderBrush="#2A3950"
                     BorderThickness="1"
                     Padding="10" />
            <Button x:Name="UseSuggestionButton" Grid.Column="1" Content="Use Suggestion" MinWidth="130" Margin="10,0,0,0" IsEnabled="False" />
            <Button x:Name="SendButton" Grid.Column="2" Content="Send" MinWidth="110" Margin="10,0,0,0" />
          </Grid>
        </Grid>
      </TabItem>

      <TabItem x:Name="TimelineTab">
        <TabItem.Header>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Timeline" />
            <Border x:Name="TimelineTabBadgePanel"
                    IsVisible="False"
                    Background="#3E3A1F"
                    CornerRadius="10"
                    Padding="6,1"
                    MinWidth="20">
              <TextBlock x:Name="TimelineTabBadgeText"
                         Text="0"
                         HorizontalAlignment="Center"
                         FontSize="11"
                         FontWeight="SemiBold" />
            </Border>
          </StackPanel>
        </TabItem.Header>
        <Border Margin="8"
                BorderBrush="#2A3950"
                BorderThickness="1"
                CornerRadius="8"
                Background="#0F1520"
                Padding="8">
          <Grid RowDefinitions="Auto,Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Text="Execution timeline" Opacity="0.85" VerticalAlignment="Center" />
              <Button x:Name="TimelineCopyButton" Grid.Column="1" Content="Copy" MinWidth="80" Margin="8,0,0,0" />
              <Button x:Name="TimelineExportButton" Grid.Column="2" Content="Export" MinWidth="90" Margin="8,0,0,0" />
            </Grid>
            <Grid Grid.Row="1" Margin="0,8,0,8" ColumnDefinitions="180,*">
              <ComboBox x:Name="TimelineFilterCombo" SelectedIndex="0">
                <ComboBoxItem Content="All" />
                <ComboBoxItem Content="Success" />
                <ComboBoxItem Content="Failed" />
              </ComboBox>
              <TextBox x:Name="TimelineSearchBox"
                       Grid.Column="1"
                       Margin="8,0,0,0"
                       Watermark="Search timeline..." />
            </Grid>
            <TextBlock x:Name="TimelineStatusText" Grid.Row="2" Opacity="0.75" />
            <ListBox x:Name="TimelineList"
                     Grid.Row="3"
                     Margin="0,6,0,0" />
          </Grid>
        </Border>
      </TabItem>

      <TabItem Header="Config">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="220,*" Margin="8">
          <TextBlock Text="LLM Enabled" />
          <CheckBox x:Name="CfgLlmEnabled" Grid.Column="1" />

          <TextBlock Grid.Row="1" Text="Provider" Margin="0,8,0,0" />
          <ComboBox x:Name="CfgLlmProvider" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" SelectedIndex="0">
            <ComboBoxItem Content="ollama" />
            <ComboBoxItem Content="openai" />
            <ComboBoxItem Content="llama.cpp" />
          </ComboBox>

          <TextBlock Grid.Row="2" Text="Endpoint" Margin="0,8,0,0" />
          <TextBox x:Name="CfgLlmEndpoint" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" />

          <TextBlock Grid.Row="3" Text="Model" Margin="0,8,0,0" />
          <TextBox x:Name="CfgLlmModel" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" />

          <TextBlock Grid.Row="4" Text="Timeout Seconds" Margin="0,8,0,0" />
          <TextBox x:Name="CfgLlmTimeout" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" />

          <TextBlock Grid.Row="5" Text="Max Tokens" Margin="0,8,0,0" />
          <TextBox x:Name="CfgLlmMaxTokens" Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" />

          <TextBlock Grid.Row="6" Text="Allow Remote Endpoint" Margin="0,8,0,0" />
          <CheckBox x:Name="CfgLlmAllowRemote" Grid.Row="6" Grid.Column="1" Margin="0,8,0,0" />

          <TextBlock Grid.Row="7" Text="Audio Backend" Margin="0,8,0,0" />
          <ComboBox x:Name="CfgAudioBackend" Grid.Row="7" Grid.Column="1" Margin="0,8,0,0" SelectedIndex="0">
            <ComboBoxItem Content="auto" />
            <ComboBoxItem Content="wasapi" />
            <ComboBoxItem Content="dshow" />
            <ComboBoxItem Content="avfoundation" />
            <ComboBoxItem Content="pipewire" />
            <ComboBoxItem Content="pulse" />
            <ComboBoxItem Content="alsa" />
          </ComboBox>

          <TextBlock Grid.Row="8" Text="Audio Device (optional)" Margin="0,8,0,0" />
          <TextBox x:Name="CfgAudioDevice" Grid.Row="8" Grid.Column="1" Margin="0,8,0,0" />

          <TextBlock Grid.Row="9" Text="Audio Input Selector" Margin="0,8,0,0" />
          <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <ComboBox x:Name="CfgAudioDeviceSelector" MinWidth="320" />
            <Button x:Name="CfgAudioRefreshButton" Content="Refresh Inputs" MinWidth="130" />
          </StackPanel>

          <TextBlock Grid.Row="10" Text="Capture Primary Display Only" Margin="0,8,0,0" />
          <CheckBox x:Name="CfgPrimaryDisplayOnly" Grid.Row="10" Grid.Column="1" Margin="0,8,0,0" />

          <TextBlock Grid.Row="11" Text="Media Folder" Margin="0,8,0,0" />
          <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBox x:Name="CfgMediaOutputDirectory" MinWidth="320" />
            <Button x:Name="CfgOpenDataFolderButton" Content="Open Data Folder" MinWidth="140" />
          </StackPanel>

          <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button x:Name="CfgLoadButton" Content="Reload Config" MinWidth="120" />
            <Button x:Name="CfgSaveButton" Content="Save Config" MinWidth="120" />
            <Button x:Name="CfgTestLlmButton" Content="Test LLM" MinWidth="120" />
            <Button x:Name="CfgRunFirstSetupButton" Content="Run First Setup" MinWidth="130" />
          </StackPanel>

          <StackPanel Grid.Row="13" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button x:Name="CfgCheckUpdatesButton" Content="Check Updates Now" MinWidth="140" />
            <Button x:Name="CfgApplyUpdateButton" Content="Apply Downloaded Update" MinWidth="180" />
            <TextBlock x:Name="CfgUpdateStatusText" VerticalAlignment="Center" />
          </StackPanel>

          <TextBox x:Name="CfgStatusBox"
                   Grid.Row="14"
                   Grid.ColumnSpan="2"
                   Margin="0,12,0,0"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Background="#0F1520"
                   BorderBrush="#2A3950"
                   BorderThickness="1" />
        </Grid>
      </TabItem>

      <TabItem Header="Tasks">
        <Grid RowDefinitions="Auto,220,Auto,Auto,*" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="TasksRefreshButton" Content="Refresh Tasks" MinWidth="120" />
            <Button x:Name="TasksRunButton" Content="Run Selected" MinWidth="120" />
            <Button x:Name="TasksDeleteButton" Content="Delete Selected" MinWidth="130" />
          </StackPanel>

          <ListBox x:Name="TasksList" Grid.Row="1" Margin="0,10,0,10" />

          <Grid Grid.Row="2" ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Text="Task Name" VerticalAlignment="Center" />
            <TextBox x:Name="TaskNameInput" Grid.Column="1" Margin="8,0,0,0" />
            <TextBlock Grid.Row="1" Text="Intent" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBox x:Name="TaskIntentInput" Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" />
            <TextBlock Grid.Row="2" Text="Description" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBox x:Name="TaskDescriptionInput" Grid.Row="2" Grid.Column="1" Margin="8,8,0,0" />
          </Grid>

          <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button x:Name="TaskSaveButton" Content="Save Task" MinWidth="120" />
            <TextBlock x:Name="TasksStatusText" VerticalAlignment="Center" />
          </StackPanel>

          <Border Grid.Row="4"
                  Margin="0,12,0,0"
                  Padding="10"
                  CornerRadius="8"
                  Background="#101723"
                  BorderBrush="#2A3950"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <Grid ColumnDefinitions="Auto,Auto,*" VerticalAlignment="Center">
                <TextBlock Text="Macro Recorder" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button x:Name="MacroRecordToggleButton" Grid.Column="1" Content="Start Recording" MinWidth="130" Margin="10,0,0,0" />
                <Button x:Name="MacroClearButton" Grid.Column="2" Content="Clear" MinWidth="90" HorizontalAlignment="Left" Margin="10,0,0,0" />
              </Grid>

              <ListBox x:Name="MacroList"
                       Grid.Row="1"
                       Margin="0,10,0,0"
                       MinHeight="110"
                       MaxHeight="180" />

              <Grid Grid.Row="2" Margin="0,10,0,0" ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBox x:Name="MacroStepEditorInput" Watermark="Selected step command..." />
                <Button x:Name="MacroApplyEditButton" Grid.Column="1" Content="Apply" MinWidth="80" Margin="8,0,0,0" />
                <Button x:Name="MacroRemoveStepButton" Grid.Column="2" Content="Remove" MinWidth="86" Margin="8,0,0,0" />
                <Button x:Name="MacroMoveUpButton" Grid.Column="3" Content="Up" MinWidth="64" Margin="8,0,0,0" />
                <Button x:Name="MacroMoveDownButton" Grid.Column="4" Content="Down" MinWidth="70" Margin="8,0,0,0" />
              </Grid>

              <Grid Grid.Row="3" Margin="0,10,0,0" ColumnDefinitions="130,90,Auto,*">
                <TextBlock Text="Add Wait (sec)" VerticalAlignment="Center" />
                <TextBox x:Name="MacroAddWaitSecondsInput" Grid.Column="1" Text="1" />
                <Button x:Name="MacroAddWaitButton" Grid.Column="2" Content="Add Wait Step" MinWidth="120" Margin="8,0,0,0" />
                <TextBlock x:Name="MacroStatusText" Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.85" />
              </Grid>

              <Grid Grid.Row="4" Margin="0,10,0,0" ColumnDefinitions="120,*,120,*,Auto">
                <TextBlock Text="Macro Name" VerticalAlignment="Center" />
                <TextBox x:Name="MacroNameInput" Grid.Column="1" Margin="8,0,0,0" Watermark="e.g. open-vscode-file" />
                <TextBlock Grid.Column="2" Text="Description" VerticalAlignment="Center" Margin="12,0,0,0" />
                <TextBox x:Name="MacroDescriptionInput" Grid.Column="3" Margin="8,0,0,0" Watermark="Recorded macro task" />
                <Button x:Name="MacroSaveTaskButton" Grid.Column="4" Content="Save as Task" MinWidth="120" Margin="10,0,0,0" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Schedules">
        <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="SchedulesRefreshButton" Content="Refresh Schedules" MinWidth="140" />
            <Button x:Name="SchedulesRunButton" Content="Run Selected" MinWidth="120" />
            <Button x:Name="SchedulesDeleteButton" Content="Delete Selected" MinWidth="130" />
          </StackPanel>

          <ListBox x:Name="SchedulesList" Grid.Row="1" Margin="0,10,0,10" />

          <Grid Grid.Row="2" ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <TextBlock Text="Schedule Id (optional)" VerticalAlignment="Center" />
            <TextBox x:Name="ScheduleIdInput" Grid.Column="1" Margin="8,0,0,0" />
            <TextBlock Grid.Row="1" Text="Task Name" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBox x:Name="ScheduleTaskNameInput" Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" />
            <TextBlock Grid.Row="2" Text="Start UTC (yyyy-MM-dd HH:mm)" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBox x:Name="ScheduleStartAtInput" Grid.Row="2" Grid.Column="1" Margin="8,8,0,0" />
            <TextBlock Grid.Row="3" Text="Interval Seconds" VerticalAlignment="Center" Margin="0,8,0,0" />
            <TextBox x:Name="ScheduleIntervalInput" Grid.Row="3" Grid.Column="1" Margin="8,8,0,0" />
            <TextBlock Grid.Row="4" Text="Enabled" VerticalAlignment="Center" Margin="0,8,0,0" />
            <CheckBox x:Name="ScheduleEnabledInput" Grid.Row="4" Grid.Column="1" Margin="8,8,0,0" IsChecked="True" />
          </Grid>

          <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button x:Name="ScheduleSaveButton" Content="Save Schedule" MinWidth="130" />
            <TextBlock x:Name="SchedulesStatusText" VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Goals">
        <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="GoalsRefreshButton" Content="Refresh Goals" MinWidth="130" />
            <Button x:Name="GoalsToggleAutoButton" Content="Toggle Auto" MinWidth="120" />
            <Button x:Name="GoalsDoneButton" Content="Mark Done" MinWidth="110" />
            <Button x:Name="GoalsRemoveButton" Content="Remove" MinWidth="100" />
          </StackPanel>

          <ListBox x:Name="GoalsList" Grid.Row="1" Margin="0,10,0,10">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                  <CheckBox Grid.Column="0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding AutoRunEnabled}"
                            Checked="OnGoalAutoChecked"
                            Unchecked="OnGoalAutoUnchecked" />
                  <TextBlock Grid.Column="1"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             Text="{Binding Label}"
                             TextTrimming="CharacterEllipsis" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Grid Grid.Row="2" ColumnDefinitions="150,*" RowDefinitions="Auto">
            <TextBlock Text="New Goal Text" VerticalAlignment="Center" />
            <TextBox x:Name="GoalTextInput" Grid.Column="1" Margin="8,0,0,0" />
          </Grid>

          <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <Button x:Name="GoalAddButton" Content="Add Goal" MinWidth="120" />
            <TextBlock x:Name="GoalsStatusText" VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Media">
        <Grid RowDefinitions="Auto,*" ColumnDefinitions="360,*" Margin="8">
          <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
            <Button x:Name="MediaRefreshButton" Content="Refresh Media" MinWidth="120" />
            <Button x:Name="MediaOpenFolderButton" Content="Open Folder" MinWidth="110" />
            <Button x:Name="MediaOpenButton" Content="Open Selected" MinWidth="120" />
            <Button x:Name="MediaCopyPathButton" Content="Copy Path" MinWidth="100" />
            <Button x:Name="MediaDeleteButton" Content="Delete Selected" MinWidth="130" />
            <TextBlock x:Name="MediaStatusText" VerticalAlignment="Center" Opacity="0.8" Margin="8,0,0,0" />
          </StackPanel>

          <Border Grid.Row="1"
                  Margin="0,10,10,0"
                  Padding="8"
                  BorderBrush="#2A3950"
                  BorderThickness="1"
                  CornerRadius="8"
                  Background="#0F1520">
            <ListBox x:Name="MediaList" />
          </Border>

          <Border Grid.Row="1"
                  Grid.Column="1"
                  Margin="0,10,0,0"
                  Padding="10"
                  BorderBrush="#2A3950"
                  BorderThickness="1"
                  CornerRadius="8"
                  Background="#0F1520">
            <Grid RowDefinitions="Auto,Auto,*">
              <TextBlock x:Name="MediaPreviewTitleText" Text="No media selected" FontWeight="SemiBold" />
              <TextBox x:Name="MediaPreviewInfoText"
                       Grid.Row="1"
                       Margin="0,8,0,8"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       BorderThickness="0"
                       Background="#0F1520" />
              <Border Grid.Row="2"
                      BorderBrush="#2A3950"
                      BorderThickness="1"
                      CornerRadius="6"
                      Background="#111A2A">
                <Image x:Name="MediaPreviewImage" Stretch="Uniform" />
              </Border>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Audit">
        <Grid RowDefinitions="Auto,*" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="AuditRefreshButton" Content="Refresh Audit" MinWidth="120" />
            <Button x:Name="AuditCopyButton" Content="Copy Audit" MinWidth="110" />
            <Button x:Name="AuditClearButton" Content="Clear View" MinWidth="110" />
          </StackPanel>
          <TextBox x:Name="AuditBox"
                   Grid.Row="1"
                   Margin="0,10,0,0"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Background="#0F1520"
                   BorderBrush="#2A3950"
                   BorderThickness="1"
                   FontFamily="Cascadia Mono, Consolas, monospace"
                   FontSize="12" />
        </Grid>
      </TabItem>

      <TabItem Header="Diagnostics">
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="DiagRefreshButton" Content="Run Environment Check" MinWidth="180" />
            <Button x:Name="DiagCopyButton" Content="Copy" MinWidth="90" />
          </StackPanel>
          <Border Grid.Row="1"
                  Margin="0,8,0,0"
                  Padding="8"
                  CornerRadius="6"
                  Background="#111A2A"
                  BorderBrush="#2A3950"
                  BorderThickness="1">
            <TextBlock x:Name="HealthText" Text="Health: loading..." />
          </Border>
          <TextBlock x:Name="DiagStatusText" Grid.Row="2" Margin="0,8,0,0" Opacity="0.8" />
          <TextBox x:Name="DiagBox"
                   Grid.Row="3"
                   Margin="0,10,0,0"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Background="#0F1520"
                   BorderBrush="#2A3950"
                   BorderThickness="1"
                   FontFamily="Cascadia Mono, Consolas, monospace"
                   FontSize="12" />
        </Grid>
      </TabItem>

      <TabItem Header="Wiki">
        <Grid RowDefinitions="Auto,Auto,*" Margin="8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="WikiSearchBox"
                     Width="360"
                     Watermark="Search in wiki (commands, safety, setup...)"
                     Background="#0F1520"
                     BorderBrush="#2A3950"
                     BorderThickness="1" />
            <Button x:Name="WikiResetSearchButton" Content="Reset" MinWidth="90" />
            <Button x:Name="WikiCopyButton" Content="Copy" MinWidth="90" />
          </StackPanel>
          <TextBlock x:Name="WikiStatusText" Grid.Row="1" Margin="0,8,0,0" Opacity="0.8" />
          <TextBox x:Name="WikiContentBox"
                   Grid.Row="2"
                   Margin="0,10,0,0"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   Background="#0F1520"
                   BorderBrush="#2A3950"
                   BorderThickness="1"
                   FontFamily="Cascadia Mono, Consolas, monospace"
                   FontSize="12" />
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
